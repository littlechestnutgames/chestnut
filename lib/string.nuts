fn repeat(s : String, times : Integer = 0) returns String
    let str = s
    while loop_index < times
        str += s
    endwhile
    return str
endfn

fn wrap(s : String, string_len : Integer) returns String
    let i = 0
    while i < length(s)
        
    endwhile
endfn

fn replace(str : String, old : String, new : String, occurrences : Integer = -1) returns String
    return __internal_replace__(str, old, new, occurrences)
endfn

